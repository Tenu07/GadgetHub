@{
    ViewData["Title"] = "Home Page";
}

<div class="welcome-section text-center fade-in">
    <h1 class="page-title">Welcome to GadgetHub!</h1>
    <p class="lead">Shop the latest gadgets from top distributors.</p>
    <hr />
    <div class="row justify-content-center">
        <div class="col-md-4 mb-4 fade-in-delay-1">
            <div class="card h-100">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title text-primary"><i class="fas fa-box fa-2x mb-3"></i> Products</h5>
                    <p class="card-text flex-grow-1">Browse our wide range of gadgets and electronics.</p>
                    <a href="/Customer/Products" class="btn btn-primary mt-auto">Browse Products</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4 fade-in-delay-2">
            <div class="card h-100">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title text-success"><i class="fas fa-cart-plus fa-2x mb-3"></i> Place Order</h5>
                    <p class="card-text flex-grow-1">Order your favorite gadgets with the best deals.</p>
                    <a href="/Customer/PlaceOrder" class="btn btn-success mt-auto">Place Order</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4 fade-in-delay-3">
            <div class="card h-100">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title text-info"><i class="fas fa-list-check fa-2x mb-3"></i> My Orders</h5>
                    <p class="card-text flex-grow-1">Track your orders and delivery status easily.</p>
                    <a href="/Customer/Orders" class="btn btn-info mt-auto">My Orders</a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row justify-content-center mt-5">
    <div class="col-md-8 fade-in-delay-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-star me-2"></i>Why Choose GadgetHub?</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <ul class="list-unstyled">
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i> Latest gadgets from top brands</li>
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i> Competitive pricing</li>
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i> Fast delivery</li>
                        </ul>
                    </div>
                    <div class="col-md-6">
                        <ul class="list-unstyled">
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i> 24/7 customer support</li>
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i> Easy returns</li>
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i> Secure payment</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
