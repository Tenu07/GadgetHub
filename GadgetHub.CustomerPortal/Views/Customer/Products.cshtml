@model List<GadgetHub.Models.Product>
@{
    ViewData["Title"] = "Browse Products";
}

<div class="page-title">
    <h2><i class="fas fa-box me-2"></i>Browse Products</h2>
    <p class="lead">Discover the latest gadgets and electronics from top brands.</p>
</div>

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-list me-2"></i>Available Products</h5>
                <div class="input-group" style="width: 300px;">
                    <input type="text" class="form-control" placeholder="Search products...">
                    <button class="btn btn-outline-secondary" type="button"><i class="fas fa-search"></i></button>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Description</th>
                                <th>Price</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var product in Model)
                            {
                                <tr>
                                    <td>@product.Id</td>
                                    <td>@product.Name</td>
                                    <td>@product.Description</td>
                                    <td>$@product.Price.ToString("F2")</td>
                                    <td>
                                        <a href="/Customer/PlaceOrder" class="btn btn-sm btn-primary"><i class="fas fa-cart-plus me-1"></i>Add to Cart</a>
                                    </td>
                                </tr>
                            }
                            <!-- Sample data for demonstration -->
                            <tr>
                                <td>101</td>
                                <td>iPhone 15 Pro</td>
                                <td>Latest Apple smartphone with advanced camera system</td>
                                <td>$999.00</td>
                                <td>
                                    <a href="/Customer/PlaceOrder" class="btn btn-sm btn-primary"><i class="fas fa-cart-plus me-1"></i>Add to Cart</a>
                                </td>
                            </tr>
                            <tr>
                                <td>102</td>
                                <td>Samsung Galaxy S24</td>
                                <td>Flagship Android smartphone with powerful processor</td>
                                <td>$899.00</td>
                                <td>
                                    <a href="/Customer/PlaceOrder" class="btn btn-sm btn-primary"><i class="fas fa-cart-plus me-1"></i>Add to Cart</a>
                                </td>
                            </tr>
                            <tr>
                                <td>103</td>
                                <td>MacBook Air M2</td>
                                <td>Ultra-thin laptop with Apple M2 chip</td>
                                <td>$1,199.00</td>
                                <td>
                                    <a href="/Customer/PlaceOrder" class="btn btn-sm btn-primary"><i class="fas fa-cart-plus me-1"></i>Add to Cart</a>
                                </td>
                            </tr>
                            <tr>
                                <td>104</td>
                                <td>iPad Pro</td>
                                <td>Professional tablet with M2 chip and Liquid Retina XDR display</td>
                                <td>$1,099.00</td>
                                <td>
                                    <a href="/Customer/PlaceOrder" class="btn btn-sm btn-primary"><i class="fas fa-cart-plus me-1"></i>Add to Cart</a>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
