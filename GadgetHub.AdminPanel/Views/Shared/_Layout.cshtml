<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GadgetHub Admin</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/admin-site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GadgetHub.AdminPanel.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="sidebar d-flex flex-column">
        <div class="p-4">
            <h4 class="text-white"><i class="fas fa-cogs"></i> GadgetHub Admin</h4>
        </div>
        <hr class="text-white mx-3">
        <ul class="nav flex-column">
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "Dashboard" ? "active" : "")" asp-area="" asp-controller="Admin" asp-action="Dashboard">
                    <i class="fas fa-home"></i> <span>Dashboard</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "Products" ? "active" : "")" asp-area="" asp-controller="Admin" asp-action="Products">
                    <i class="fas fa-box"></i> <span>Products</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "Orders" ? "active" : "")" asp-area="" asp-controller="Admin" asp-action="Orders">
                    <i class="fas fa-shopping-cart"></i> <span>Orders</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "Customers" ? "active" : "")" asp-area="" asp-controller="Admin" asp-action="Customers">
                    <i class="fas fa-users"></i> <span>Customers</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/">
                    <i class="fas fa-arrow-left"></i> <span>Back to Site</span>
                </a>
            </li>
        </ul>
    </div>
    
    <div class="main-content">
        <nav class="top-navbar navbar navbar-expand">
            <div class="container-fluid">
                <h5 class="mb-0">@ViewData["Title"]</h5>
                <div class="d-flex">
                    <span class="badge bg-primary"><i class="fas fa-circle me-1"></i> Admin</span>
                </div>
            </div>
        </nav>
        
        <div class="content-wrapper fade-in">
            <main role="main">
                @RenderBody()
            </main>
        </div>
        
        <footer class="border-top footer text-muted">
            <div class="container-fluid">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        &copy; 2025 - GadgetHub Admin Panel
                    </div>
                    <div>
                        <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                    </div>
                </div>
            </div>
        </footer>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
