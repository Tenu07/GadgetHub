@model List<GadgetHub.Models.Product>
@{
    ViewData["Title"] = "All Products";
}

<div class="page-title">
    <h2><i class="fas fa-box me-2"></i>All Products</h2>
    <p class="lead">Manage all products available in the GadgetHub system.</p>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="fas fa-list me-2"></i>Product List</h5>
        <a href="/Admin/AddProduct" class="btn btn-primary"><i class="fas fa-plus me-1"></i>Add Product</a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Price</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Model)
                    {
                        <tr>
                            <td>@product.Id</td>
                            <td>@product.Name</td>
                            <td>@product.Description</td>
                            <td>$@product.Price.ToString("F2")</td>
                            <td>
                                <a href="#" class="btn btn-sm btn-outline-primary me-1"><i class="fas fa-edit"></i></a>
                                <a href="#" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></a>
                            </td>
                        </tr>
                    }
                    <!-- Sample data for demonstration -->
                    <tr>
                        <td>101</td>
                        <td>iPhone 15 Pro</td>
                        <td>Latest Apple smartphone with advanced camera system</td>
                        <td>$999.00</td>
                        <td>
                            <a href="#" class="btn btn-sm btn-outline-primary me-1"><i class="fas fa-edit"></i></a>
                            <a href="#" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                    <tr>
                        <td>102</td>
                        <td>Samsung Galaxy S24</td>
                        <td>Flagship Android smartphone with powerful processor</td>
                        <td>$899.00</td>
                        <td>
                            <a href="#" class="btn btn-sm btn-outline-primary me-1"><i class="fas fa-edit"></i></a>
                            <a href="#" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                    <tr>
                        <td>103</td>
                        <td>MacBook Air M2</td>
                        <td>Ultra-thin laptop with Apple M2 chip</td>
                        <td>$1,199.00</td>
                        <td>
                            <a href="#" class="btn btn-sm btn-outline-primary me-1"><i class="fas fa-edit"></i></a>
                            <a href="#" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
