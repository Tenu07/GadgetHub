@model List<GadgetHub.Models.Order>
@{
    ViewData["Title"] = "All Orders";
}

<div class="page-title">
    <h2><i class="fas fa-shopping-cart me-2"></i>All Orders</h2>
    <p class="lead">Manage all orders in the GadgetHub system.</p>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="fas fa-list me-2"></i>Order List</h5>
        <div class="input-group" style="width: 300px;">
            <input type="text" class="form-control" placeholder="Search orders...">
            <button class="btn btn-outline-secondary" type="button"><i class="fas fa-search"></i></button>
        </div>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Customer ID</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Total</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td>@order.OrderId</td>
                            <td>@order.CustomerId</td>
                            <td>@order.OrderDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                <span class="badge bg-@(order.Status == "Pending" ? "warning" : order.Status == "Confirmed" ? "info" : order.Status == "Shipped" ? "primary" : "success")">@order.Status</span>
                            </td>
                            <td>$0.00</td>
                            <td>
                                <a href="#" class="btn btn-sm btn-outline-primary me-1"><i class="fas fa-eye"></i></a>
                                <a href="#" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></a>
                            </td>
                        </tr>
                    }
                    <!-- Sample data for demonstration -->
                    <tr>
                        <td>ORD-2025-001</td>
                        <td>CUST-101</td>
                        <td>Jul 28, 2025</td>
                        <td><span class="badge bg-warning">Pending</span></td>
                        <td>$1,299.00</td>
                        <td>
                            <a href="#" class="btn btn-sm btn-outline-primary me-1"><i class="fas fa-eye"></i></a>
                            <a href="#" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                    <tr>
                        <td>ORD-2025-002</td>
                        <td>CUST-102</td>
                        <td>Jul 27, 2025</td>
                        <td><span class="badge bg-info">Confirmed</span></td>
                        <td>$899.00</td>
                        <td>
                            <a href="#" class="btn btn-sm btn-outline-primary me-1"><i class="fas fa-eye"></i></a>
                            <a href="#" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                    <tr>
                        <td>ORD-2025-003</td>
                        <td>CUST-103</td>
                        <td>Jul 26, 2025</td>
                        <td><span class="badge bg-success">Delivered</span></td>
                        <td>$1,199.00</td>
                        <td>
                            <a href="#" class="btn btn-sm btn-outline-primary me-1"><i class="fas fa-eye"></i></a>
                            <a href="#" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
