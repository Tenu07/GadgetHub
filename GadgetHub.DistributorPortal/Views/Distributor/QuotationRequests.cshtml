@model List<GadgetHub.Models.QuotationRequest>
<h2>Quotation Requests</h2>
<table class="table">
    <thead>
        <tr>
            <th>Product ID</th>
            <th>Quantity</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var req in Model)
        {
            <tr>
                <td>@req.ProductId</td>
                <td>@req.Quantity</td>
            </tr>
        }
    </tbody>
</table>
